<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/floating_root"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_floating_collapsed"
    android:padding="10dp"
    android:elevation="10dp">

    <LinearLayout
        android:id="@+id/layout_collapsed"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/tv_cny_price"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="¥----"
            android:textColor="#FFE082"
            android:textSize="16sp"
            android:textStyle="bold"
            android:shadowColor="#66000000"
            android:shadowDx="0"
            android:shadowDy="1"
            android:shadowRadius="3"
            android:singleLine="true" />

        <TextView
            android:id="@+id/tv_usd_price"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="$----"
            android:textColor="#DDE7FF"
            android:textSize="11sp"
            android:layout_marginTop="1dp"
            android:singleLine="true" />

        <TextView
            android:id="@+id/tv_change"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="--"
            android:textColor="#AAB0C8"
            android:textSize="10sp"
            android:layout_marginTop="1dp"
            android:singleLine="true" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/layout_expanded"
        android:layout_width="226dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_floating_expanded"
        android:padding="14dp"
        android:elevation="12dp"
        android:visibility="gone">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="实时黄金"
            android:textColor="#99FFFFFF"
            android:textSize="11sp" />

        <TextView
            android:id="@+id/tv_exp_cny"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="¥----/克"
            android:textColor="#FFE082"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginTop="2dp" />

        <TextView
            android:id="@+id/tv_exp_usd"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="伦敦金 $----/盎司"
            android:textColor="#DDE7FF"
            android:textSize="13sp"
            android:layout_marginTop="6dp" />

        <TextView
            android:id="@+id/tv_exp_change"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="涨跌 --"
            android:textColor="#AAB0C8"
            android:textSize="12sp"
            android:layout_marginTop="4dp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#33FFD700"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="10dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <TextView
                android:id="@+id/tv_exp_cache"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="数据源: 实时"
                android:textColor="#8E95AA"
                android:textSize="10sp" />
            <TextView
                android:id="@+id/tv_exp_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="更新: --:--"
                android:textColor="#8E95AA"
                android:textSize="10sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="end|center_vertical"
            android:layout_marginTop="12dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="点按收起 · 长按拖动"
                android:textColor="#667088"
                android:textSize="9sp" />

            <ImageView
                android:id="@+id/btn_refresh"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:padding="5dp"
                android:layout_marginEnd="8dp"
                android:src="@drawable/ic_refresh"
                android:background="@drawable/bg_dark_button"
                android:contentDescription="刷新" />

            <ImageView
                android:id="@+id/btn_close"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:padding="5dp"
                android:src="@drawable/ic_close"
                android:background="@drawable/bg_dark_button"
                android:contentDescription="关闭" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
