<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/floating_root"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_floating_collapsed"
    android:padding="8dp">

    <!-- 折叠态：简洁两行 -->
    <LinearLayout
        android:id="@+id/layout_collapsed"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_vertical">

        <!-- 第一行：国内金价 -->
        <TextView
            android:id="@+id/tv_cny_price"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="¥----"
            android:textColor="#FFD700"
            android:textSize="14sp"
            android:textStyle="bold"
            android:singleLine="true" />

        <!-- 第二行：伦敦金（可隐藏） -->
        <TextView
            android:id="@+id/tv_usd_price"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="$----"
            android:textColor="#E0E0E0"
            android:textSize="11sp"
            android:singleLine="true" />
    </LinearLayout>

    <!-- 展开态 -->
    <LinearLayout
        android:id="@+id/layout_expanded"
        android:layout_width="200dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_floating_expanded"
        android:padding="12dp"
        android:visibility="gone">

        <!-- 国内金价大字 -->
        <TextView
            android:id="@+id/tv_exp_cny"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="¥----/克"
            android:textColor="#FFD700"
            android:textSize="18sp"
            android:textStyle="bold" />

        <!-- 伦敦金 -->
        <TextView
            android:id="@+id/tv_exp_usd"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="伦敦金 $----/盎司"
            android:textColor="#E0E0E0"
            android:textSize="13sp"
            android:layout_marginTop="4dp" />

        <!-- 分隔线 -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#33FFD700"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="6dp" />

        <!-- 更新时间 -->
        <TextView
            android:id="@+id/tv_exp_time"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="更新: --:--"
            android:textColor="#888888"
            android:textSize="11sp" />

        <!-- 按钮行 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="end"
            android:layout_marginTop="8dp">

            <ImageView
                android:id="@+id/btn_refresh"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginEnd="12dp"
                android:src="@drawable/ic_refresh"
                android:contentDescription="刷新" />

            <ImageView
                android:id="@+id/btn_close"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_close"
                android:contentDescription="关闭" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
