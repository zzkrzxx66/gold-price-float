<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/floating_root"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_floating_gradient"
    android:padding="10dp"
    android:elevation="8dp">

    <!-- 折叠态 -->
    <LinearLayout
        android:id="@+id/layout_collapsed"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/tv_cny_price"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="¥----/克"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:textStyle="bold"
            android:includeFontPadding="false"
            android:singleLine="true" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="2dp">

            <TextView
                android:id="@+id/tv_usd_price"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="$----/oz"
                android:textColor="#E0E0E0"
                android:textSize="10sp"
                android:singleLine="true" />

            <TextView
                android:id="@+id/tv_change"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:text=""
                android:textSize="10sp"
                android:singleLine="true" />
        </LinearLayout>
    </LinearLayout>

    <!-- 展开态 -->
    <LinearLayout
        android:id="@+id/layout_expanded"
        android:layout_width="210dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone"
        android:background="@drawable/bg_floating_expanded_gradient"
        android:padding="14dp">

        <TextView
            android:id="@+id/tv_exp_cny"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="¥----/克"
            android:textColor="#FFD700"
            android:textSize="19sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_exp_usd"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="伦敦金 $----/盎司"
            android:textColor="#E0E0E0"
            android:textSize="13sp"
            android:layout_marginTop="3dp" />

        <TextView
            android:id="@+id/tv_exp_change"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="13sp"
            android:layout_marginTop="4dp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#22FFD700"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="6dp" />

        <TextView
            android:id="@+id/tv_exp_time"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="更新: --:--:--"
            android:textColor="#888888"
            android:textSize="10sp" />

        <TextView
            android:id="@+id/tv_exp_cache"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="[离线数据]"
            android:textColor="#FF9800"
            android:textSize="10sp"
            android:visibility="gone" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="end"
            android:layout_marginTop="8dp">

            <ImageView
                android:id="@+id/btn_refresh"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginEnd="16dp"
                android:src="@drawable/ic_refresh"
                android:contentDescription="刷新" />

            <ImageView
                android:id="@+id/btn_close"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_close"
                android:contentDescription="关闭" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
