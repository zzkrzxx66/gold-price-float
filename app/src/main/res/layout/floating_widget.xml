<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/floating_root"
    android:layout_width="wrap_content" android:layout_height="wrap_content"
    android:orientation="vertical" android:padding="0dp">

    <LinearLayout
        android:id="@+id/layout_collapsed"
        android:layout_width="132dp" android:layout_height="wrap_content"
        android:orientation="vertical" android:background="@drawable/bg_floating_collapsed"
        android:paddingLeft="12dp" android:paddingRight="12dp" android:paddingTop="9dp" android:paddingBottom="9dp">
        <TextView android:id="@+id/tv_cny_price" android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="¥--.--/克" android:textColor="#F0D28A" android:textSize="16sp" android:textStyle="bold" android:singleLine="true" />
        <TextView android:id="@+id/tv_usd_price" android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="$----/oz" android:textColor="#AAB2BD" android:textSize="11sp" android:singleLine="true" android:layout_marginTop="2dp" />
        <TextView android:id="@+id/tv_change" android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="--" android:textColor="#777F8A" android:textSize="10sp" android:singleLine="true" android:layout_marginTop="2dp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/layout_expanded" android:layout_width="236dp" android:layout_height="wrap_content"
        android:orientation="vertical" android:visibility="gone" android:background="@drawable/bg_floating_expanded" android:padding="14dp">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center_vertical" android:orientation="horizontal">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="实时金价" android:textColor="#E9EDF2" android:textSize="15sp" android:textStyle="bold" />
            <ImageView android:id="@+id/btn_refresh" android:layout_width="28dp" android:layout_height="28dp" android:padding="6dp" android:src="@drawable/ic_refresh" android:tint="#AAB2BD" />
            <ImageView android:id="@+id/btn_close" android:layout_width="28dp" android:layout_height="28dp" android:padding="6dp" android:src="@drawable/ic_close" android:tint="#AAB2BD" />
        </LinearLayout>
        <TextView android:id="@+id/tv_exp_cny" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="14dp" android:text="¥--.--/克" android:textColor="#F0D28A" android:textSize="28sp" android:textStyle="bold" />
        <TextView android:id="@+id/tv_exp_change" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="3dp" android:text="较上次 --" android:textColor="#777F8A" android:textSize="12sp" />
        <TextView android:id="@+id/tv_exp_usd" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="10dp" android:text="伦敦金 $----/oz" android:textColor="#C2C8D0" android:textSize="14sp" />
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:orientation="horizontal">
            <TextView android:id="@+id/tv_exp_time" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="--:--:--" android:textColor="#777F8A" android:textSize="11sp" />
            <TextView android:id="@+id/tv_exp_cache" android:layout_width="wrap_content" android:layout_height="wrap_content" android:background="@drawable/bg_tiny_chip" android:paddingLeft="8dp" android:paddingRight="8dp" android:paddingTop="3dp" android:paddingBottom="3dp" android:text="实时" android:textColor="#8C949E" android:textSize="10sp" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
