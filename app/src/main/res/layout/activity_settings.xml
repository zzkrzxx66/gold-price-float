<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android" android:layout_width="match_parent" android:layout_height="match_parent" android:background="@drawable/bg_app_gradient" android:fillViewport="true">
<LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="20dp">
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="设置" android:textColor="#F2F4F6" android:textSize="28sp" android:textStyle="bold" />
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="控制刷新、显示和价格提醒" android:textColor="#7F8893" android:textSize="13sp" android:layout_marginTop="4dp" android:layout_marginBottom="18dp" />

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:background="@drawable/bg_surface" android:padding="16dp" android:layout_marginBottom="14dp">
        <TextView android:id="@+id/tv_refresh_label" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="刷新频率" android:textColor="#E9EDF2" android:textSize="15sp" android:textStyle="bold" />
        <RadioGroup android:id="@+id/rg_refresh" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:layout_marginTop="10dp">
            <RadioButton android:id="@+id/rb_15s" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="15 秒" android:textColor="#C8CED6" android:buttonTint="#D6A84F" />
            <RadioButton android:id="@+id/rb_30s" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="30 秒（推荐）" android:textColor="#C8CED6" android:buttonTint="#D6A84F" />
            <RadioButton android:id="@+id/rb_60s" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="60 秒" android:textColor="#C8CED6" android:buttonTint="#D6A84F" />
            <RadioButton android:id="@+id/rb_300s" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="5 分钟" android:textColor="#C8CED6" android:buttonTint="#D6A84F" />
        </RadioGroup>
    </LinearLayout>

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:background="@drawable/bg_surface" android:padding="16dp" android:layout_marginBottom="14dp">
        <TextView android:id="@+id/tv_opacity_label" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="悬浮窗透明度" android:textColor="#E9EDF2" android:textSize="15sp" android:textStyle="bold" />
        <SeekBar android:id="@+id/seek_opacity" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="10dp" android:progressTint="#D6A84F" android:thumbTint="#D6A84F" />
        <Switch android:id="@+id/sw_london" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:text="显示伦敦金（美元/盎司）" android:textColor="#C8CED6" android:thumbTint="#D6A84F" android:trackTint="#353B43" />
    </LinearLayout>

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:background="@drawable/bg_surface" android:padding="16dp" android:layout_marginBottom="18dp">
        <Switch android:id="@+id/sw_alert" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="价格提醒（按 ¥/克）" android:textColor="#E9EDF2" android:textStyle="bold" android:thumbTint="#D6A84F" android:trackTint="#353B43" />
        <LinearLayout android:id="@+id/layout_alert_settings" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:layout_marginTop="12dp">
            <EditText android:id="@+id/et_alert_above" android:layout_width="match_parent" android:layout_height="48dp" android:background="@drawable/bg_input_dark" android:hint="高于此价格提醒，例如 780" android:textColorHint="#59616B" android:textColor="#E9EDF2" android:textSize="14sp" android:inputType="numberDecimal" />
            <EditText android:id="@+id/et_alert_below" android:layout_width="match_parent" android:layout_height="48dp" android:layout_marginTop="10dp" android:background="@drawable/bg_input_dark" android:hint="低于此价格提醒，例如 720" android:textColorHint="#59616B" android:textColor="#E9EDF2" android:textSize="14sp" android:inputType="numberDecimal" />
            <Button android:id="@+id/btn_save_alert" android:layout_width="match_parent" android:layout_height="46dp" android:layout_marginTop="12dp" android:background="@drawable/bg_primary_button" android:text="保存提醒" android:textColor="#121212" android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

    <Button android:id="@+id/btn_back" android:layout_width="match_parent" android:layout_height="48dp" android:background="@drawable/bg_secondary_button" android:text="完成" android:textColor="#C8CED6" />
</LinearLayout>
</ScrollView>
