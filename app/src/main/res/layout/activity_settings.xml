<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0F0F1E"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- 标题 -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp">

            <Button
                android:id="@+id/btn_back"
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:backgroundTint="#2A2A4A"
                android:text="← 返回"
                android:textColor="#FFD700"
                android:textSize="12sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:text="⚙ 设置"
                android:textColor="#FFD700"
                android:textSize="20sp"
                android:textStyle="bold" />
        </RelativeLayout>

        <!-- 刷新频率卡片 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="16dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:id="@+id/tv_refresh_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="刷新频率"
                android:textColor="#CCCCCC"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <RadioGroup
                android:id="@+id/rg_refresh"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <RadioButton android:id="@+id/rb_15s" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="15秒" android:textColor="#999999" android:buttonTint="#FFD700" />
                <RadioButton android:id="@+id/rb_30s" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="30秒" android:textColor="#999999" android:buttonTint="#FFD700" />
                <RadioButton android:id="@+id/rb_60s" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="1分钟" android:textColor="#999999" android:buttonTint="#FFD700" />
                <RadioButton android:id="@+id/rb_300s" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="5分钟" android:textColor="#999999" android:buttonTint="#FFD700" />
            </RadioGroup>
        </LinearLayout>

        <!-- 透明度卡片 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="16dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:id="@+id/tv_opacity_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="透明度: 90%"
                android:textColor="#CCCCCC"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <SeekBar
                android:id="@+id/seek_opacity"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="100"
                android:progress="90"
                android:progressTint="#FFD700"
                android:thumbTint="#FFD700" />
        </LinearLayout>

        <!-- 显示选项卡片 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="16dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="显示选项"
                android:textColor="#CCCCCC"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <Switch
                    android:id="@+id/sw_london"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:thumbTint="#FFD700"
                    android:trackTint="#333355" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="  显示伦敦金（XAU/USD）"
                    android:textColor="#CCCCCC"
                    android:textSize="13sp"
                    android:layout_marginStart="12dp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <Switch
                    android:id="@+id/sw_compact"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:thumbTint="#FFD700"
                    android:trackTint="#333355" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="  紧凑模式"
                    android:textColor="#CCCCCC"
                    android:textSize="13sp"
                    android:layout_marginStart="12dp" />
            </LinearLayout>
        </LinearLayout>

        <!-- 金价提醒卡片 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="16dp"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <Switch
                    android:id="@+id/sw_alert"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:thumbTint="#FFD700"
                    android:trackTint="#333355" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="  金价提醒"
                    android:textColor="#CCCCCC"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginStart="12dp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/layout_alert_settings"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="高于目标价（元/克）"
                    android:textColor="#AAAAAA"
                    android:textSize="12sp" />

                <EditText
                    android:id="@+id/et_alert_above"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:background="#1A1A2E"
                    android:hint="如: 800"
                    android:inputType="numberDecimal"
                    android:textColor="#FFFFFF"
                    android:textColorHint="#666666"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="低于目标价（元/克）"
                    android:textColor="#AAAAAA"
                    android:textSize="12sp" />

                <EditText
                    android:id="@+id/et_alert_below"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:background="#1A1A2E"
                    android:hint="如: 700"
                    android:inputType="numberDecimal"
                    android:textColor="#FFFFFF"
                    android:textColorHint="#666666"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:layout_marginBottom="12dp" />

                <Button
                    android:id="@+id/btn_save_alert"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:background="@drawable/bg_button_primary"
                    android:text="保存提醒价格"
                    android:textColor="#1A1A2E"
                    android:textSize="13sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="设置自动保存，返回即生效"
            android:textColor="#444444"
            android:textSize="11sp"
            android:layout_gravity="center" />

    </LinearLayout>
</ScrollView>
